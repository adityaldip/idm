// IDM Platform — Prisma Schema Design
// Copy to prisma/schema.prisma during Phase 1 scaffolding
// PostgreSQL provider

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  CUSTOMER_SERVICE
}

enum ShipmentStatus {
  CREATED
  PICKED_UP
  IN_WAREHOUSE
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
}

enum ServiceType {
  EXPRESS
  STANDARD
  FREIGHT
  COLD_CHAIN
  LAST_MILE
  INTERNATIONAL
}

enum VehicleType {
  MOTORCYCLE
  VAN
  TRUCK
  CONTAINER
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
}

enum DriverStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContentBlockType {
  HERO
  ABOUT
  SERVICES_INTRO
  COVERAGE
  CTA
  FOOTER
}

enum ActivityType {
  SHIPMENT_CREATED
  SHIPMENT_UPDATED
  TRACKING_ADDED
  CUSTOMER_CREATED
  USER_LOGIN
  SETTINGS_CHANGED
  EXPORT_GENERATED
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  avatarUrl     String?
  role          Role      @default(OPERATOR)
  isActive      Boolean   @default(true)
  branchId      String?
  branch        Branch?   @relation(fields: [branchId], references: [id])
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  createdShipments   Shipment[]        @relation("ShipmentCreatedBy")
  trackingUpdates    TrackingHistory[] @relation("TrackingUpdatedBy")
  activities         ActivityLog[]
  createdNews        News[]            @relation("NewsAuthor")

  @@index([role])
  @@index([branchId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id          String   @id @default(cuid())
  code        String   @unique // e.g. CUS-00001
  name        String
  email       String?
  phone       String
  company     String?
  address     String?
  city        String?
  province    String?
  postalCode  String?
  taxId       String?  // NPWP
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shipments Shipment[]

  @@index([phone])
  @@index([email])
  @@map("customers")
}

// ─────────────────────────────────────────────────────────────────────────────
// BRANCHES
// ─────────────────────────────────────────────────────────────────────────────

model Branch {
  id          String   @id @default(cuid())
  code        String   @unique // e.g. BR-JKT-01
  name        String
  address     String
  city        String
  province    String
  postalCode  String?
  phone       String
  email       String?
  latitude    Float?
  longitude   Float?
  isActive    Boolean  @default(true)
  isHeadquarters Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users              User[]
  originShipments    Shipment[]        @relation("OriginBranch")
  destinationShipments Shipment[]      @relation("DestinationBranch")
  trackingEvents     TrackingHistory[]
  vehicles           Vehicle[]

  @@index([city])
  @@map("branches")
}

// ─────────────────────────────────────────────────────────────────────────────
// SHIPMENTS & TRACKING
// ─────────────────────────────────────────────────────────────────────────────

model Shipment {
  id                String         @id @default(cuid())
  trackingNumber    String         @unique // e.g. IDM2026000001
  status            ShipmentStatus @default(CREATED)
  serviceType       ServiceType    @default(STANDARD)

  // Parties
  customerId        String
  customer          Customer       @relation(fields: [customerId], references: [id])
  senderName        String
  senderPhone       String
  senderAddress     String
  senderCity        String
  recipientName     String
  recipientPhone    String
  recipientAddress  String
  recipientCity     String

  // Routing
  originBranchId    String?
  originBranch      Branch?        @relation("OriginBranch", fields: [originBranchId], references: [id])
  destinationBranchId String?
  destinationBranch Branch?        @relation("DestinationBranch", fields: [destinationBranchId], references: [id])

  // Package details
  weight            Float?         // kg
  dimensions        String?        // LxWxH cm
  packageCount      Int            @default(1)
  description       String?
  declaredValue     Decimal?       @db.Decimal(12, 2)

  // Pricing
  shippingCost      Decimal?       @db.Decimal(12, 2)
  insuranceCost     Decimal?       @db.Decimal(12, 2)
  totalCost         Decimal?       @db.Decimal(12, 2)

  // Tracking state (denormalized for fast reads)
  currentLocation   String?
  estimatedDelivery DateTime?
  actualDelivery    DateTime?

  // Assignment
  vehicleId         String?
  vehicle           Vehicle?       @relation(fields: [vehicleId], references: [id])
  driverId          String?
  driver            Driver?        @relation(fields: [driverId], references: [id])

  // Meta
  notes             String?
  createdById       String?
  createdBy         User?          @relation("ShipmentCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  trackingHistory   TrackingHistory[]

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
  @@index([originBranchId])
  @@index([destinationBranchId])
  @@map("shipments")
}

model TrackingHistory {
  id          String         @id @default(cuid())
  shipmentId  String
  shipment    Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status      ShipmentStatus
  location    String
  description String?
  branchId    String?
  branch      Branch?        @relation(fields: [branchId], references: [id])
  updatedById String?
  updatedBy   User?          @relation("TrackingUpdatedBy", fields: [updatedById], references: [id])
  timestamp   DateTime       @default(now())

  @@index([shipmentId, timestamp])
  @@map("tracking_histories")
}

// ─────────────────────────────────────────────────────────────────────────────
// FLEET
// ─────────────────────────────────────────────────────────────────────────────

model Vehicle {
  id            String        @id @default(cuid())
  plateNumber   String        @unique
  type          VehicleType
  brand         String?
  model         String?
  year          Int?
  capacity      Float?        // kg or m³ depending on type
  status        VehicleStatus @default(AVAILABLE)
  branchId      String?
  branch        Branch?       @relation(fields: [branchId], references: [id])
  lastServiceAt DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  shipments Shipment[]
  drivers   Driver[]   @relation("AssignedVehicle")

  @@index([status])
  @@index([branchId])
  @@map("vehicles")
}

model Driver {
  id            String       @id @default(cuid())
  code          String       @unique // e.g. DRV-001
  name          String
  phone         String
  licenseNumber String       @unique
  licenseExpiry DateTime?
  status        DriverStatus @default(ACTIVE)
  vehicleId     String?
  vehicle       Vehicle?     @relation("AssignedVehicle", fields: [vehicleId], references: [id])
  photoUrl      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  shipments Shipment[]

  @@index([status])
  @@map("drivers")
}

// ─────────────────────────────────────────────────────────────────────────────
// CMS — PUBLIC WEBSITE CONTENT
// ─────────────────────────────────────────────────────────────────────────────

model News {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  excerpt     String?
  content     String     @db.Text
  coverImage  String?
  status      NewsStatus @default(DRAFT)
  publishedAt DateTime?
  authorId    String?
  author      User?      @relation("NewsAuthor", fields: [authorId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
  @@map("news")
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  company   String?
  role      String?
  content   String   @db.Text
  rating    Int      @default(5) // 1-5
  avatarUrl String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("testimonials")
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String
  website   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("partners")
}

model ContentBlock {
  id        String           @id @default(cuid())
  type      ContentBlockType @unique
  title     String?
  subtitle  String?
  body      String?          @db.Text
  imageUrl  String?
  metadata  Json?            // Flexible key-value for section-specific data
  updatedAt DateTime         @updatedAt

  @@map("content_blocks")
}

model ServiceOffering {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String      @db.Text
  icon        String?     // Lucide icon name
  serviceType ServiceType
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  features    String[]    // Bullet points
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([isActive, sortOrder])
  @@map("service_offerings")
}

model CoverageArea {
  id        String   @id @default(cuid())
  province  String
  cities    String[] // Array of city names
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([province])
  @@map("coverage_areas")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTACT & LEADS
// ─────────────────────────────────────────────────────────────────────────────

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
  @@map("contact_submissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// SYSTEM
// ─────────────────────────────────────────────────────────────────────────────

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  group     String   @default("general") // general, tracking, email, branding
  updatedAt DateTime @updatedAt

  @@index([group])
  @@map("settings")
}

model ActivityLog {
  id         String       @id @default(cuid())
  type       ActivityType
  entityType String?      // e.g. "Shipment", "Customer"
  entityId   String?
  message    String
  metadata   Json?
  userId     String?
  user       User?        @relation(fields: [userId], references: [id])
  createdAt  DateTime     @default(now())

  @@index([type, createdAt])
  @@index([userId])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// TRACKING NUMBER GENERATION (reference logic, not in schema)
// ─────────────────────────────────────────────────────────────────────────────
//
// Format: IDM + YYYY + 6-digit sequence
// Example: IDM2026000042
//
// Implement via:
//   1. PostgreSQL sequence per year, OR
//   2. Atomic counter in Settings table (key: "tracking_seq_2026")
//
// ─────────────────────────────────────────────────────────────────────────────
